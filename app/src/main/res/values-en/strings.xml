    <string name="settings_lg_reset_defaults">Reset to Defaults</string>
    <string name="settings_lg_hint_vibrancy">Vibrancy lets background colors bleed through the frosted glass, creating an iOS/macOS-style vibrant color effect. Disable for pure blur only.</string>
    <string name="settings_lg_hint_blur">Blur controls the base blur radius of the frosted glass (in dp). Higher values create stronger blur but may impact performance.</string>
    <string name="settings_lg_hint_lens_dilation">Lens Dilation controls how much the lens expands (in dp). Higher values widen the refraction area, simulating concave/convex lens effects.</string>
    <string name="settings_lg_hint_lens_blur">Lens Blur controls the blur spread at lens edges (in dp). Works together with Dilation to shape the overall lens intensity.</string>
    <string name="settings_lg_hint_chromatic_aberration">Chromatic aberration simulates camera lens color fringing, creating rainbow-like color separation at lens edges. Only supported by some components (e.g., LiquidSwitch).</string>
    <string name="settings_lg_hint_highlight">Highlight reflection simulates ambient light reflecting on the glass surface, enhancing the 3D glass texture. Only supported by some components (e.g., LiquidSwitch, LiquidDialog).</string>
